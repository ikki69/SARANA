<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvAdminNama"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nama Peminjam"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="PINJAM"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerAdminItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginVertical="6dp" />

    <TextView
        android:id="@+id/tvAdminKeperluan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Keperluan: -"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnApprove"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Setujui"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/btnReject"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:backgroundTint="@color/accent_red"
            android:text="Tolak"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:minHeight="0dp" />
    </LinearLayout>

</LinearLayout>
