<?xml version="1.0" encoding="utf-8"?>
<!-- Item aset - Figma style: circular icon + details -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_card"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon circle (Figma: colored circle per category) -->
    <LinearLayout
        android:id="@+id/iconContainer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_button_primary"
        android:gravity="center"
        android:layout_marginEnd="12dp">
        <TextView
            android:id="@+id/tvAsetIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💻"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAsetNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Aset"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAsetKategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori • Kondisi"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <View android:layout_width="match_parent" android:layout_height="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAsetStok"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stok: 5/5"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <View android:layout_width="12dp" android:layout_height="match_parent" />

            <TextView
                android:id="@+id/tvAsetDipinjam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dipinjam: 0"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status badge -->
    <TextView
        android:id="@+id/tvAsetStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tersedia"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_status_dikembalikan"
        android:textColor="@color/status_kembali_text" />

</LinearLayout>
