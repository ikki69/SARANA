<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background_cream">

        <!-- Dark header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/header_dark"
            android:orientation="vertical">

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/abc_ic_ab_back_material"
                    android:layout_marginEnd="12dp"
                    android:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Inventaris Aset"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Teal sub-header search -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Cari aset atau kategori..."
                    android:textColorHint="#9E9E9E"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:inputType="text"
                    android:singleLine="true" />

            </LinearLayout>
        </LinearLayout>

        <!-- Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEMUA ASET"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <!-- ListView -->
        <ListView
            android:id="@+id/listViewAset"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="14dp"
            android:paddingBottom="12dp"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddAset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary"
        app:tint="#FFFFFF"
        android:visibility="gone" />

</FrameLayout>
