<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/primary"
        android:gravity="center"
        android:orientation="vertical">

        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_splash"
            android:backgroundTint="#FFFFFF"
            android:elevation="4dp" />

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Pengguna Aset"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="pengguna@kampus.ac.id"
            android:textColor="#B2DFDB"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENGATURAN"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:gravity="center_vertical"
                android:text="Edit Profil"
                android:textColor="@color/text_primary"
                android:drawablePadding="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:gravity="center_vertical"
                android:text="Notifikasi"
                android:textColor="@color/text_primary"
                android:drawablePadding="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:gravity="center_vertical"
                android:text="Pusat Bantuan"
                android:textColor="@color/text_primary"
                android:drawablePadding="16dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_secondary"
            android:text="KELUAR"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="Versi Aplikasi 1.0.0"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>
</LinearLayout>
