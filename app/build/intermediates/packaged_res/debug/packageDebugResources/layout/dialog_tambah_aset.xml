<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Aset"
        android:textSize="12sp"
        android:textColor="#757575" />
    <EditText
        android:id="@+id/etAddNamaAset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contoh: Laptop ASUS ROG"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kategori"
        android:textSize="12sp"
        android:textColor="#757575" />
    <Spinner
        android:id="@+id/spAddKategori"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jumlah Stok"
        android:textSize="12sp"
        android:textColor="#757575" />
    <EditText
        android:id="@+id/etAddStok"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan angka"
        android:inputType="number"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kondisi"
        android:textSize="12sp"
        android:textColor="#757575" />
    <Spinner
        android:id="@+id/spAddKondisi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
