<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardApproveRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_approve_card_urgent"
    android:orientation="vertical"
    android:paddingStart="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Header: ID, Time, Priority -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:id="@+id/tvApproveReqId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#REQ-0048"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvApproveTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="27 jam lalu"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvApprovePriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="#F9E2E2"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="• Mendesak"
                android:textColor="#C75B5B"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- User Info -->
        <TextView
            android:id="@+id/tvApproveName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rifqi"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvApproveUserInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="202310066 - Mhs. JTIK 2020"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- Asset Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/containerApproveItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@+id/tvApproveDateNeeded"
                android:orientation="vertical">
                <!-- Items like "Stopkontak x2" will be added here -->
            </LinearLayout>

            <TextView
                android:id="@+id/tvApproveDateNeeded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Butuh: 09 Mar"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApproveRequest"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.5"
                android:text="Setujui"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp"
                app:backgroundTint="#FFFFFF"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRejectRequest"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Tolak"
                android:textColor="#C75B5B"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:strokeColor="#C75B5B"
                app:strokeWidth="1.5dp"
                app:backgroundTint="#FFFFFF"
                android:layout_marginEnd="10dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMoreOptions"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▼"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1.5dp"
                app:backgroundTint="#FFFFFF"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
