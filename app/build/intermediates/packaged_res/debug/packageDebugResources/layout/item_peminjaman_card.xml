<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardHistoryRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_approve_card_normal"
    android:orientation="vertical"
    android:paddingStart="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvHistoryIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:id="@+id/tvHistoryId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#PM-0312"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHistoryStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="#D7E5F0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="• Aktif"
                android:textColor="@color/kpi_blue"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvHistoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rifqi"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHistoryAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Akun: @username"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="italic"
            android:visibility="gone"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvHistoryUserInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192310001 - Mhs. Aktif"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/containerHistoryItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@+id/layoutHistoryDeadline"
                android:orientation="vertical">
                <!-- Items -->
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutHistoryDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEADLINE"
                    android:textColor="@color/text_hint"
                    android:textSize="8sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvHistoryDeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11 Mar"
                    android:textColor="#1C1C1C"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="▾ Detail"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>
</LinearLayout>
